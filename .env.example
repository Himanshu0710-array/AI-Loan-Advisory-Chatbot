# --- Google Gemini API Key (Optional if LOCAL_ONLY_MODE=true) ---
# Get your free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Execution Mode ---
# Set to true to run 100% locally without Google Gemini API (uses extractive local answers)
# Set to false to use Gemini for generating high-quality answers (embeddings still run locally!)
LOCAL_ONLY_MODE=true

# --- Security & Admin ---
# Key required for admin operations like uploading/clearing documents via X-Admin-Key header
ADMIN_API_KEY=secret_admin_key_123

# --- Server Config ---
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
FLASK_DEBUG=true
