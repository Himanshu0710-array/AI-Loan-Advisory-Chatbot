# --- Generation (optional) ---
# Leave blank + set LOCAL_ONLY_MODE=true if you don't want any external API calls.
GEMINI_API_KEY=your_gemini_api_key_here

# --- Privacy mode ---
# true  = no data ever leaves this server (embeddings + generation both local)
# false = embeddings stay local, but top-K snippets + question are sent to Gemini
LOCAL_ONLY_MODE=false

# --- Security ---
# Required to use /api/documents/upload and /api/documents/clear.
# Leave blank to disable those endpoints entirely.
ADMIN_API_KEY=change_me_to_a_long_random_string

# Comma-separated list of origins allowed to call this API.
ALLOWED_ORIGINS=http://localhost:5000

# Set true only for local development.
FLASK_DEBUG=false
